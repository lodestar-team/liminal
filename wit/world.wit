package liminal:node@0.2.0;

// ---------------------------------------------------------------------------
// The universal node interface.
//
// Every Liminal component — decoder, enricher, sink, or anything you dream up —
// exports exactly this one function. The host wires components into a DAG from
// a manifest and pipes opaque byte payloads (JSON by convention) along the
// edges, blind to what's inside. That blindness is the whole point: a new
// pipeline shape is a config change, never a host recompile.
// ---------------------------------------------------------------------------

interface node {
    /// Transform one input message into zero or more output messages.
    ///
    /// - input   : an opaque payload (the SDK encodes/decodes JSON for you).
    /// - ok([])  : message consumed/filtered — nothing flows downstream.
    /// - ok([..]): one or more messages, each routed to every successor edge.
    /// - err(s)  : a recoverable, per-message error; the host logs it and
    ///             carries on with the next message.
    transform: func(input: list<u8>) -> result<list<list<u8>>, string>;
}

/// Every component binary implements this world. One world to rule them all.
world liminal-node {
    export node;
}

// ---------------------------------------------------------------------------
// Namespaced key-value store (W4).
//
// A minimal store mirroring `wasi:keyvalue/store`, pared to what Liminal needs
// so it runs on the Wasmtime 44 base (the official `wasmtime-wasi-keyvalue`
// crate is Wasmtime-45-only). The host scopes every key by the granting node's
// declared namespace, so no component can read or write another's keys —
// isolation enforced by the host, invisible to the guest.
// ---------------------------------------------------------------------------

interface store {
    /// Fetch a value, or `none` if the key is absent.
    get: func(key: string) -> option<list<u8>>;
    /// Store a value under a key, overwriting any existing value.
    set: func(key: string, value: list<u8>);
    /// Remove a key. A no-op if it wasn't present.
    delete: func(key: string);
    /// Whether a value exists for the key.
    exists: func(key: string) -> bool;
}

/// The world the host implements to provide the store to granted components.
world kv-provider {
    import store;
}

/// A component that both processes messages and uses the key-value store.
world liminal-node-kv {
    export node;
    import store;
}
