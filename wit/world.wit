package liminal:node@0.2.0;

// ---------------------------------------------------------------------------
// The universal node interface.
//
// Every Liminal component — decoder, enricher, sink, or anything you dream up —
// exports exactly this one function. The host wires components into a DAG from
// a manifest and pipes opaque byte payloads (JSON by convention) along the
// edges, blind to what's inside. That blindness is the whole point: a new
// pipeline shape is a config change, never a host recompile.
// ---------------------------------------------------------------------------

interface node {
    /// Transform one input message into zero or more output messages.
    ///
    /// - input   : an opaque payload (the SDK encodes/decodes JSON for you).
    /// - ok([])  : message consumed/filtered — nothing flows downstream.
    /// - ok([..]): one or more messages, each routed to every successor edge.
    /// - err(s)  : a recoverable, per-message error; the host logs it and
    ///             carries on with the next message.
    transform: func(input: list<u8>) -> result<list<list<u8>>, string>;
}

/// Every component binary implements this world. One world to rule them all.
world liminal-node {
    export node;
}
